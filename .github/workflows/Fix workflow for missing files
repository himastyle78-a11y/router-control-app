name: Build APK

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v4
    
    - name: Setup Flutter
      uses: subosito/flutter-action@v2
      with:
        flutter-version: '3.19.0'
        channel: 'stable'
    
    - name: Create Flutter Project
      run: |
        flutter create --project-name router_control_app flutter_app
        cd flutter_app
        flutter pub add http
    
    - name: Copy Source Files
      run: |
        mkdir -p flutter_app/lib
        cp main.dart flutter_app/lib/ 2>/dev/null || true
        cp pubspec.yaml flutter_app/ 2>/dev/null || true
        cp analysis_options.yaml flutter_app/ 2>/dev/null || true
    
    - name: Install dependencies
      run: |
        cd flutter_app
        flutter pub get
    
    - name: Build APK
      run: |
        cd flutter_app
        flutter build apk --release
    
    - name: Upload APK
      uses: actions/upload-artifact@v4
      with:
        name: router-control-apk
        path: flutter_app/build/app/outputs/flutter-apk/app-release.apk
        retention-days: 30
